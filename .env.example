# StatementIQ — Environment Configuration
# Copy this file to .env and add your key

# Anthropic API key — ONE key for everything
# Powers: Vision fallback (scanned PDFs), transaction parsing, memo generation
# Without this, rules-based components still work fine (metadata, math, regex parsing)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server config
HOST=0.0.0.0
PORT=8000
